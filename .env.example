# ─────────────────────────────────────────
# Moments in Music — environment config
# Copy to .env and fill in real values
# ─────────────────────────────────────────

# Simple shared-password auth (v1)
# Pick any phrase — both users sign in with this
NUXT_AUTH_PASSWORD=change-me
# Any long random string — used to sign the auth cookie
NUXT_AUTH_SECRET=replace-with-random-32-char-string

# MongoDB Atlas (optional v1 — app works with mock data if unset)
NUXT_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
NUXT_MONGO_DB=moments_in_music

# Clerk (future — replaces shared password once ready)
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
NUXT_CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Google Drive (optional — for episode pack folder linking)
# NUXT_GDRIVE_ROOT_FOLDER_ID=xxxxxxxx
